# 环境配置示例
# 复制此文件为 .env 并填写实际值

# GitHub配置
GITHUB_TOKEN=你的GitHub令牌
GITHUB_REPO=wu18346579595/auto-deploy-demo

# 部署服务器配置
DEPLOY_SERVER_IP=你的服务器IP
DEPLOY_SERVER_USER=用户名
DEPLOY_PATH=/var/www/app

# 飞书通知配置
FEISHU_WEBHOOK_URL=你的飞书Webhook URL
FEISHU_CHAT_ID=飞书群ID

# 部署策略
AUTO_DEPLOY_ENABLED=true
DEPLOY_TIME_WINDOW=09:00-18:00
WEEKDAYS_ONLY=true
REQUIRE_APPROVAL_FOR_PRODUCTION=true